{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Current Java File",
            "type": "shell",
            "command": "chcp 65001; javac -encoding UTF-8 \"${file}\"; if ($LASTEXITCODE -eq 0) { java \"-Dfile.encoding=UTF-8\" -cp \"${fileDirname}\" \"${fileBasenameNoExtension}\" }",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Compile All Java Files",
            "type": "shell",
            "command": "chcp 65001; javac -encoding UTF-8 0702\\*.java",
            "problemMatcher": []
        }
    ]
}
